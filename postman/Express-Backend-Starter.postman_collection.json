{
  "info": {
    "_postman_id": "express-backend-starter-collection",
    "name": "Express Backend Starter",
    "description": "Full API collection for Express 5 + TypeScript + Prisma + MongoDB starter template.\n\n## Setup\n1. Import this collection and `local.postman_environment.json`\n2. Set session env vars in `.env`: `REMEMBER_ME_EXPIRES_IN=30d`, `SESSION_CLEANUP_CRON=0 3 * * *`, `SESSION_CLEANUP_RETENTION_DAYS=30`\n3. Select the **Express Backend - Local** environment\n4. Run **Auth > Login (Admin - Remember Me)** or **Login (Admin - Standard)** first — tokens are saved automatically\n5. Run other requests in any order\n\n## Remember Me\n- `rememberMe: true` → session lasts `REMEMBER_ME_EXPIRES_IN` (default 30d)\n- omit `rememberMe` → session lasts `REFRESH_TOKEN_EXPIRES_IN` (default 1d)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5500" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root Welcome",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin - Remember Me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('sessionId', json.data.sessionId);",
                  "  pm.environment.set('rememberMe', String(json.data.rememberMe ?? false));",
                  "  pm.environment.set('sessionExpiresIn', json.data.sessionExpiresIn || '');",
                  "  if (json.data.accessToken) {",
                  "    const payload = JSON.parse(atob(json.data.accessToken.split('.')[1]));",
                  "    pm.environment.set('userId', payload.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"rememberMe\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Optional remember me. Session lasts REMEMBER_ME_EXPIRES_IN (default 30d). Response includes rememberMe and sessionExpiresIn."
          }
        },
        {
          "name": "Login (Admin - Standard)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('sessionId', json.data.sessionId);",
                  "  pm.environment.set('rememberMe', String(json.data.rememberMe ?? false));",
                  "  pm.environment.set('sessionExpiresIn', json.data.sessionExpiresIn || '');",
                  "  if (json.data.accessToken) {",
                  "    const payload = JSON.parse(atob(json.data.accessToken.split('.')[1]));",
                  "    pm.environment.set('userId', payload.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Standard login without rememberMe. Session lasts REFRESH_TOKEN_EXPIRES_IN (default 1d)."
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('sessionId', json.data.sessionId);",
                  "  pm.environment.set('rememberMe', String(json.data.rememberMe ?? false));",
                  "  pm.environment.set('sessionExpiresIn', json.data.sessionExpiresIn || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "User login without rememberMe. Session lasts REFRESH_TOKEN_EXPIRES_IN (default 1d)."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('sessionId', json.data.sessionId);",
                  "  pm.environment.set('rememberMe', String(json.data.rememberMe ?? false));",
                  "  pm.environment.set('sessionExpiresIn', json.data.sessionExpiresIn || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh-token"
          }
        },
        {
          "name": "Logout (Current Session)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Logout All Devices",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/logout-all"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/profile"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"{{adminPassword}}\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/change-password"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{resetToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "Sessions (User)",
      "item": [
        {
          "name": "My Active Sessions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/sessions"
          }
        }
      ]
    },
    {
      "name": "Sessions (Admin)",
      "item": [
        {
          "name": "List Active Sessions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.data && json.data.data.length > 0) {",
                  "  pm.environment.set('targetSessionId', json.data.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "searchTerm", "value": "", "disabled": true },
                { "key": "userId", "value": "{{userId}}", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Session By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/sessions/{{targetSessionId}}"
          }
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/sessions/{{targetSessionId}}"
          }
        },
        {
          "name": "Revoke All User Sessions",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/sessions/user/{{userId}}"
          }
        },
        {
          "name": "Revoke Multiple Users Sessions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"{{userId}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/sessions/revoke-users"
          }
        },
        {
          "name": "Revoke All Sessions (Super Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/sessions"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"0123456789\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/register"
          }
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/profile"
          }
        },
        {
          "name": "Update User By ID (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/{{userId}}"
          }
        }
      ]
    }
  ]
}
