# Application
NODE_ENV=development
# Application
NODE_ENV=development
PORT=5500

# Database (MongoDB) — Prisma requires a replica set (Atlas works out of the box)
# Local: mongod --replSet rs0 then run rs.initiate() in mongosh
# DATABASE_URL="mongodb://localhost:27017/your-db-name?replicaSet=rs0"
DATABASE_URL="mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.k5v5ibx.mongodb.net/starter-template?retryWrites=true&w=majority"

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=your_jwt_secret_key_here
EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d
REMEMBER_ME_EXPIRES_IN=30d

# Session cleanup cron (daily at 3:00 AM)
SESSION_CLEANUP_CRON=0 3 * * *
SESSION_CLEANUP_RETENTION_DAYS=30

# Password Reset
RESET_PASS_TOKEN=your_reset_password_secret_here
RESET_PASS_TOKEN_EXPIRES_IN=10m
RESET_PASS_LINK=http://localhost:5500/reset-password

# Email (Gmail SMTP)
EMAIL=your-email@gmail.com
APP_PASS=your_gmail_app_password

# Super Admin Seed (created on first boot if not exists)
SUPER_ADMIN_EMAIL=admin@gmail.com
SUPER_ADMIN_PASSWORD=12345678
SUPER_ADMIN_FIRST_NAME=Mr. Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PHONE=0112345678
